import pandas as pd 
import numpy as np 

np.random.seed(42) 
n = 100 

data = pd.DataFrame({ 
    "Student_ID": range(1, n+1), 
    "Gender": np.random.choice(["Male", "Female"], n), 
    "Study_Hours": np.random.normal(5, 2, n),  # average 5 hrs 
    "Attendance": np.random.normal(85, 10, n), 
    "Midterm_Score": np.random.normal(70, 15, n), 
    "Final_Score": np.random.normal(75, 12, n), 
    "Assignments_Avg": np.random.normal(80, 10, n) 
}) 

# Introduce missing values 
data.loc[5, "Study_Hours"] = np.nan 
data.loc[10, "Midterm_Score"] = np.nan 

# Introduce inconsistencies 
data.loc[15, "Attendance"] = 150   # invalid attendance 
data.loc[20, "Final_Score"] = -10  # invalid score 

# Introduce outliers 
data.loc[25, "Study_Hours"] = 20   # extreme study hours 
data.loc[30, "Midterm_Score"] = 200  # impossible score 

df = pd.DataFrame(data) 

#print(df) 
#print(data.head()) 

print(df.isnull().sum()) 

# handling the null values 
df['Study_Hours'] = df['Study_Hours'].fillna(df['Study_Hours'].mean()) 
df['Midterm_Score'] = df['Midterm_Score'].fillna(df['Midterm_Score'].mean()) 

print(df.isnull().sum()) 

# handaling the inconsistency 

# Attendance should not exceed 100% 
df['Attendance'] = df['Attendance'].apply(lambda x: 100 if x > 100 else x) 

# Final_Score should not be negative 
df['Final_Score'] = df['Final_Score'].apply(lambda x: np.nan if x < 0 else x) 
df['Final_Score'] = df['Final_Score'].fillna(df['Final_Score'].mean()) 

# Midterm_Score cannot exceed 100 
df['Midterm_Score'] = df['Midterm_Score'].apply(lambda x: 100 if x > 100 else x) 

print(df) 

# checking for outliers 
import matplotlib.pyplot as plt 

plt.figure(figsize=(10,8)) 

# Boxplot for Study_Hours 
plt.subplot(2,2,1) 
plt.boxplot(df['Study_Hours']) 
plt.title('Study Hours') 

# Boxplot for Midterm_Score 
plt.subplot(2,2,2) 
plt.boxplot(df['Midterm_Score']) 
plt.title('Midterm Score') 

# Boxplot for Final_Score 
plt.subplot(2,2,3) 
plt.boxplot(df['Final_Score']) 
plt.title('Final Score') 

# Boxplot for Attendance 
plt.subplot(2,2,4) 
plt.boxplot(df['Attendance']) 
plt.title('Attendance') 

plt.tight_layout() 
plt.show() 

# handling the outliers 

# Select numeric columns to treat outliers 
numeric_cols = ['Study_Hours', 'Midterm_Score', 'Final_Score', 
                'Assignments_Avg', 'Attendance'] 

for col in numeric_cols: 
    
    Q1 = df[col].quantile(0.25) 
    Q3 = df[col].quantile(0.75) 
    IQR = Q3 - Q1 

    lower_bound = Q1 - 1.5 * IQR 
    upper_bound = Q3 + 1.5 * IQR 

    median_val = df[col].median() 

    df[col] = np.where(df[col] > upper_bound, median_val, df[col]) 
    df[col] = np.where(df[col] < lower_bound, median_val, df[col]) 

plt.figure(figsize=(10,8)) 

plt.subplot(2,2,1) 
plt.boxplot(df['Study_Hours']) 
plt.title('Study Hours') 

# Boxplot for Midterm_Score 
plt.subplot(2,2,2) 
plt.boxplot(df['Midterm_Score']) 
plt.title('Midterm Score') 

# Boxplot for Final_Score 
plt.subplot(2,2,3) 
plt.boxplot(df['Final_Score']) 
plt.title('Final Score') 

# Boxplot for Attendance 
plt.subplot(2,2,4) 
plt.boxplot(df['Attendance']) 
plt.title('Attendance') 

plt.tight_layout() 
plt.show() 

df['Attendance_Log'] = np.log(df['Attendance']) 

print(df)  explain each line of code


